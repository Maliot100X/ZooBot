{
  "name": "zoobot",
  "version": "0.0.16",
  "description": "Multi-agent, multi-team, multi-channel 24/7 AI assistant",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "zoobot": "packages/cli/bin/zoobot.mjs"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "concurrently -k -n core,teams,server,main \"npm run dev -w @zoobot/core\" \"npm run dev -w @zoobot/teams\" \"npm run dev -w @zoobot/server\" \"npm run dev -w @zoobot/main\"",
    "build:core": "npm run build -w @zoobot/core",
    "build:teams": "npm run build -w @zoobot/teams",
    "build:channels": "npm run build -w @zoobot/channels",
    "build:server": "npm run build -w @zoobot/server",
    "build:visualizer": "npm run build -w @zoobot/visualizer",
    "start": "npm run start -w @zoobot/main",
    "discord": "npm run discord -w @zoobot/channels",
    "telegram": "npm run telegram -w @zoobot/channels",
    "whatsapp": "npm run whatsapp -w @zoobot/channels",
    "server": "npm run start -w @zoobot/server",
    "visualize": "npm run visualize -w @zoobot/visualizer",
    "chatroom": "npm run chatroom -w @zoobot/visualizer"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.9",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "croner": "^10.0.1"
  }
}
